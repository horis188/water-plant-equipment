# ====================================================================
# 供水厂设备管理平台 - 环境变量模板
# 复制为 .env 后按需修改；.env 已在 .gitignore 中,不会被提交
# ====================================================================

# ── 后端服务 ──
PORT=3000
# 允许的跨域来源(逗号分隔),用于 SSE / API 访问控制
CORS_ORIGIN=http://localhost:5175

# ── MySQL 数据库 ──
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=swsc
MYSQL_PASSWORD=change_me_in_prod
MYSQL_DATABASE=water_plant

# ── JWT 鉴权 ──
# 生产环境务必替换为强随机字符串,例如: openssl rand -hex 32
JWT_SECRET=please-replace-with-a-long-random-secret-in-production
JWT_EXPIRES_IN=8h

# ── 上传文件目录（相对项目根） ──
UPLOAD_DIR=server/uploads

# ── 前端 (Vite) ──
# 访问端口
VITE_PORT=5175
# 后端 API 完整地址(浏览器直连/反向代理场景)
VITE_API_BASE=http://localhost:3000
