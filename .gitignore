# ====================================================================
# 依赖 / 构建产物
# ====================================================================
node_modules/
dist/
.vite/

# ====================================================================
# 运行时数据 / 上传文件(保留目录结构用 .gitkeep,内容不入库)
# ====================================================================
server/uploads/*
!server/uploads/.gitkeep

# 备份产物
backups/
*.tar.gz

# ====================================================================
# 环境变量(包含数据库密码 / JWT 密钥)
# ====================================================================
.env
.env.local
.env.*.local
!.env.example

# ====================================================================
# 日志
# ====================================================================
*.log
vite.log
server.log
npm-debug.log*

# ====================================================================
# IDE / 编辑器
# ====================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# ====================================================================
# 系统临时
# ====================================================================
.DS_Store
Thumbs.db

# ====================================================================
# 测试覆盖率
# ====================================================================
coverage/
.nyc_output/
